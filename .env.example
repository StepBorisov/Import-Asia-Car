# ============================================================================
# ZAVOZ — Environment variables
# ----------------------------------------------------------------------------
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file (it is git-ignored).
# All secrets below are used ONLY on the server and are never sent to the browser.
# ============================================================================

# --- Server ---
# Port the Express server listens on. Render sets this automatically.
PORT=3000
# "production" on Render, "development" locally.
NODE_ENV=development

# --- Telegram Bot (server-side only) ---
# Create a bot with @BotFather and paste the token here.
TELEGRAM_BOT_TOKEN=123456789:AA_your_bot_token_here
# The chat/group ID where new requests should be delivered.
# For a private managers' group, add the bot to the group and use the group's
# numeric ID (usually negative, e.g. -1001234567890).
TELEGRAM_CHAT_ID=-1001234567890

# --- Supabase (server-side only) ---
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=https://your-project.supabase.co
# SERVICE ROLE key — full access, bypasses RLS. Keep it secret, server-side only.
# NEVER expose this key in frontend code.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- Anti-spam / rate limiting (optional, has sane defaults) ---
# Max form submissions allowed per IP within the window below.
RATE_LIMIT_MAX=5
# Rate-limit window in milliseconds (default 10 minutes).
RATE_LIMIT_WINDOW_MS=600000

# --- CORS ---
# Comma-separated list of allowed origins for the API in production.
# Leave empty to allow same-origin only (recommended when frontend is served
# by this same server).
ALLOWED_ORIGINS=
